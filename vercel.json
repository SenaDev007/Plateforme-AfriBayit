{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npx turbo run build --filter=@afribayit/web...",
  "devCommand": "npx turbo run dev --filter=@afribayit/web",
  "installCommand": "npm install --workspace=apps/web --workspace=packages/ui --workspace=packages/db --workspace=packages/config --include-workspace-root",
  "framework": "nextjs",
  "outputDirectory": "apps/web/.next",
  "regions": ["cdg1"],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://afribayit-api.fly.dev/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
      ]
    }
  ],
  "crons": []
}
