# =============================================================================
# AFRIBAYIT — Environment Variables
# Copy to .env.local (web) or .env (api) and fill in values
# NEVER commit actual secrets to version control
# =============================================================================

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://afribayit:password@localhost:5432/afribayit_dev"
DIRECT_URL="postgresql://afribayit:password@localhost:5432/afribayit_dev"
REDIS_URL="redis://localhost:6379"

# ─── NEXT.JS / AUTH ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-32-char-random-secret"

# ─── OAUTH PROVIDERS ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-64-char-random-secret"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="replace-with-another-64-char-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=""
FROM_EMAIL="noreply@afribayit.com"

# ─── SMS (Africa's Talking) ──────────────────────────────────────────────────
AFRICASTALKING_USERNAME=""
AFRICASTALKING_API_KEY=""

# ─── WHATSAPP BUSINESS ───────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN=""

# ─── PAYMENTS ─────────────────────────────────────────────────────────────────
FEDAPAY_SECRET_KEY=""
FEDAPAY_PUBLIC_KEY=""
FEDAPAY_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ─── STORAGE (Cloudflare R2) ─────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="afribayit-media"
R2_PUBLIC_URL="https://media.afribayit.com"

# ─── SEARCH (Elasticsearch) ──────────────────────────────────────────────────
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_USERNAME="elastic"
ELASTICSEARCH_PASSWORD=""

# ─── MAPS ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=""

# ─── PUSH NOTIFICATIONS ──────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ─── API ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_PORT=4000
NODE_ENV="development"

# ─── MULTI-TENANCY ───────────────────────────────────────────────────────────
# Supported: bj (Bénin), ci (Côte d'Ivoire), bf (Burkina Faso), tg (Togo)
DEFAULT_COUNTRY="bj"
ALLOWED_COUNTRIES="bj,ci,bf,tg"

# ─── MONITORING ───────────────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
