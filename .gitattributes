# Normalize line endings to LF on all platforms
* text=auto eol=lf

# Force LF for these file types
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.env   text eol=lf
*.sh    text eol=lf
*.sql   text eol=lf
*.prisma text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.prettierrc text eol=lf
.eslintrc* text eol=lf
turbo.json text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
